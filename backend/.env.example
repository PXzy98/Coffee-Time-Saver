DATABASE_URL=postgresql+asyncpg://cts:cts_password@db:5432/coffee_time_saver
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me-in-production
ENCRYPTION_KEY=change-me-32-bytes-key-for-fernet

# IMAP Email Bot (optional)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX
IMAP_AUTH_METHOD=password

# OAuth2 for IMAP (set IMAP_AUTH_METHOD=oauth2 to enable)
# Yahoo: AUTHORIZE=https://api.login.yahoo.com/oauth2/request_auth  TOKEN=https://api.login.yahoo.com/oauth2/get_token  SCOPE=mail-r
# Google: AUTHORIZE=https://accounts.google.com/o/oauth2/v2/auth  TOKEN=https://oauth2.googleapis.com/token  SCOPE=https://mail.google.com/
# Microsoft: AUTHORIZE=https://login.microsoftonline.com/common/oauth2/v2.0/authorize  TOKEN=https://login.microsoftonline.com/common/oauth2/v2.0/token  SCOPE=https://outlook.office365.com/IMAP.AccessAsUser.All
IMAP_OAUTH_CLIENT_ID=
IMAP_OAUTH_CLIENT_SECRET=
IMAP_OAUTH_AUTHORIZE_URL=
IMAP_OAUTH_TOKEN_URL=
IMAP_OAUTH_REDIRECT_URI=http://localhost:8000/api/email-oauth/callback
IMAP_OAUTH_SCOPE=
IMAP_OAUTH_ACCESS_TOKEN=
IMAP_OAUTH_REFRESH_TOKEN=

# Strategy choices: hardcoded|llm, pymupdf|ocr, regex|llm, template|llm
TASK_SORTER_STRATEGY=hardcoded
PDF_PARSER_STRATEGY=pymupdf
STRUCTURER_STRATEGY=regex
BRIEFING_STRATEGY=template

# Email intelligence: regex|llm, off|llm, manual|llm
EMAIL_TASK_STRATEGY=regex
EMAIL_PROJECT_SUGGESTION=off
TASK_PROJECT_ASSOCIATION=manual
