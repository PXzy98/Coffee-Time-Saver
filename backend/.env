DATABASE_URL=postgresql+asyncpg://cts:cts_password@127.0.0.1:5432/coffee_time_saver
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET=local-dev-secret-do-not-use-in-production
ENCRYPTION_KEY=local-dev-fernet-key-32bytes-paddd
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173"]

# IMAP Email Bot (optional)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# Strategy choices: hardcoded|llm, pymupdf|ocr, regex|llm, template|llm
TASK_SORTER_STRATEGY=hardcoded
PDF_PARSER_STRATEGY=pymupdf
STRUCTURER_STRATEGY=regex
BRIEFING_STRATEGY=template
